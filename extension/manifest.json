{
  "manifest_version": 3,
  "name": "ProfileLens AI",
  "version": "2.0",
  "description": "AI-powered LinkedIn profile analyzer",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "ProfileLens AI"
  },
  "icons": {
    "48": "icons/icon48.png"
  }
}